{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/study/**",
              "ui_kits/desktop/**",
              "ui_kits/mobile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|Literata))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, Literata."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, children, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|secondary-accent)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'secondary-accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm|xs)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm' | 'xs'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|label|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, label, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|tag|children|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, tag, children, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Flashcard'] > JSXAttribute > JSXIdentifier[name!=/^(?:front|back|revealed|onReveal|style|key|ref|className|style|children)$/]",
        "message": "<Flashcard> doesn't accept that prop. Declared props: front, back, revealed, onReveal, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FsrsRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|selected|onSelect|style|key|ref|className|style|children)$/]",
        "message": "<FsrsRating> doesn't accept that prop. Declared props: options, selected, onSelect, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GoalBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|max|percent|height|style|key|ref|className|style|children)$/]",
        "message": "<GoalBar> doesn't accept that prop. Declared props: label, value, max, percent, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Heatmap'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|weeks|cell|gap|legend|style|key|ref|className|style|children)$/]",
        "message": "<Heatmap> doesn't accept that prop. Declared props: data, weeks, cell, gap, legend, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OfflineIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:synced|label|compact|style|key|ref|className|style|children)$/]",
        "message": "<OfflineIndicator> doesn't accept that prop. Declared props: synced, label, compact, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|color|height|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, color, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QueueItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|eyebrow|meta|title|subtitle|trailing|shape|status|onClick|style|key|ref|className|style|children)$/]",
        "message": "<QueueItem> doesn't accept that prop. Declared props: variant, eyebrow, meta, title, subtitle, trailing, shape, status, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QueueItem'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:next|row|done)$/]",
        "message": "<QueueItem> variant must be one of 'next' | 'row' | 'done'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QueueItem'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|square)$/]",
        "message": "<QueueItem> shape must be one of 'circle' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QueueItem'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:done|active|active-solid|pending)$/]",
        "message": "<QueueItem> status must be one of 'done' | 'active' | 'active-solid' | 'pending'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|compact|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedControl> doesn't accept that prop. Declared props: options, value, onChange, compact, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|active|onChange|footer|professorMode|style|key|ref|className|style|children)$/]",
        "message": "<Sidebar> doesn't accept that prop. Declared props: items, active, onChange, footer, professorMode, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute[name.name='footer'] > Literal[value!=/^(?:offline|none)$/]",
        "message": "<Sidebar> footer must be one of 'offline' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|shape|size|style|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, shape, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:done|active|active-solid|pending|offline|synced)$/]",
        "message": "<StatusDot> status must be one of 'done' | 'active' | 'active-solid' | 'pending' | 'offline' | 'synced'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|square)$/]",
        "message": "<StatusDot> shape must be one of 'circle' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SubjectBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|percent|color|style|key|ref|className|style|children)$/]",
        "message": "<SubjectBar> doesn't accept that prop. Declared props: name, percent, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|onChange|style|key|ref|className|style|children)$/]",
        "message": "<TabBar> doesn't accept that prop. Declared props: tabs, active, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimerRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|progress|time|seconds|label|paused|background|style|key|ref|className|style|children)$/]",
        "message": "<TimerRing> doesn't accept that prop. Declared props: size, progress, time, seconds, label, paused, background, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
