{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-console": "warn"
  },
  "ignorePatterns": [
    "**/.svelte-kit",
    "**/dist",
    "**/build",
    "**/.turbo",
    "**/.wrangler",
    "packages/design/**",
    "**/worker-configuration.d.ts"
  ]
}
