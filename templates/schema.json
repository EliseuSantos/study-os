{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://studyos.app/templates/schema.json",
  "title": "StudyOS track snapshot (.studyos.json)",
  "description": "Portable track export format. Mirrors TrackSnapshot in packages/core/src/snapshot. Keys are local ordinals (integers >= 0), never uuids.",
  "type": "object",
  "required": [
    "format",
    "version",
    "exported_at",
    "track",
    "topics",
    "cards",
    "lessons",
    "lesson_items",
    "content"
  ],
  "properties": {
    "format": { "const": "studyos-track" },
    "version": { "const": 1 },
    "exported_at": { "type": "number" },
    "track": {
      "type": "object",
      "required": ["title", "description", "mode"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "mode": { "type": "string" }
      }
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "parent_key", "title", "notes_md", "position"],
        "properties": {
          "key": { "type": "integer", "minimum": 0 },
          "parent_key": { "type": ["integer", "null"], "minimum": 0 },
          "title": { "type": "string" },
          "notes_md": { "type": ["string", "null"] },
          "position": { "type": "number" }
        }
      }
    },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic_key", "kind", "front_md", "back_md", "options_json"],
        "properties": {
          "topic_key": { "type": "integer", "minimum": 0 },
          "kind": { "type": "string" },
          "front_md": { "type": "string" },
          "back_md": { "type": ["string", "null"] },
          "options_json": { "type": ["string", "null"] }
        }
      }
    },
    "lessons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "title", "presenter_notes_md", "estimated_duration_min", "position"],
        "properties": {
          "key": { "type": "integer", "minimum": 0 },
          "title": { "type": "string" },
          "presenter_notes_md": { "type": ["string", "null"] },
          "estimated_duration_min": { "type": ["number", "null"] },
          "position": { "type": "number" }
        }
      }
    },
    "lesson_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lesson_key", "topic_key", "kind", "body_md", "position"],
        "properties": {
          "lesson_key": { "type": "integer", "minimum": 0 },
          "topic_key": { "type": ["integer", "null"], "minimum": 0 },
          "kind": { "type": "string" },
          "body_md": { "type": ["string", "null"] },
          "position": { "type": "number" }
        }
      }
    },
    "content": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic_key", "source", "external_id", "url", "title", "kind"],
        "properties": {
          "topic_key": { "type": "integer", "minimum": 0 },
          "source": { "type": "string" },
          "external_id": { "type": ["string", "null"] },
          "url": { "type": ["string", "null"] },
          "title": { "type": "string" },
          "kind": { "type": "string" }
        }
      }
    }
  }
}
